<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Profile builds talk to the local backend over plain http (10.0.2.2 on
         the Android emulator). This flag only applies to debug/profile
         builds - it is deliberately absent from the main manifest so
         release builds never carry cleartext permission. -->
    <application android:usesCleartextTraffic="true" tools:node="merge" />
</manifest>
